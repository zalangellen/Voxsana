                <svg id="ve-mic" viewBox="0 0 16 16" fill="none" style="stroke:var(--ink2)"><rect x="5" y="1" width="6" height="9" rx="3"/><path d="M2 8c0 3.3 2.7 6 6 6s6-2.7 6-6" stroke-linecap="round"/><line x1="8" y1="14" x2="8" y2="16" stroke-linecap="round"/></svg>
