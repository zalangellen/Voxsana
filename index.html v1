<script>

var S={
  specialty:null, clips:[], currentCat:'general',
  tFiles:[], pFiles:[],
  isRec:false, mediaRec:null, recog:null, timerInt:null, secs:0,
  activeClipId:null,
  isVeRec:false, veRecog:null, veTimerInt:null, veSecs:0
};

var CAT_COLORS={general:'#8a8a92',complaint:'#e05252',anamnesis:'#5b9bd5',status:'#4cad7c',diagnosis:'#c9a84c',plan:'#9b7ed4',admin:'#e0a052'};
var SRC_COLORS={dictation:'#c9a84c',lab:'#5b9bd5',prev:'#9b7ed4',img:'#4cad7c',empty:'#555'};
var CATS=['general','complaint','anamnesis','status','diagnosis','plan','admin'];

var SPEC={
  gp:`You are assisting a Hungarian General Practitioner. BNO-10 codes required.
Convert colloquial to clinical: "szúr a szíve"→precordialis fájdalom, "szédül"→vertigo/lipothymia, "dagadt a lába"→perifériás oedema, "nehezen vesz levegőt"→dyspnoea, "fáj a feje"→cephalalgia, "hányinger"→nausea, "hasmenés"→diarrhoea, "fül zúgás"→tinnitus, "vérköpés"→haemoptysis.
BNO: J06.9 légúti fertőzés, J03.9 tonsillitis, I10 hypertonia, E11 diabetes, M54.5 lumbago, J45 asthma, F32 depresszió, K29 gastritis.
Fields: chief_complaint, hpi, pmh, medications, allergies, exam_findings, diagnosis_bno, plan, prescription, referral, follow_up.`,
  cardiology:`You are assisting a Hungarian Cardiologist. BNO-10 required.
Convert: "szúr a szíve"→precordialis fájdalom, "szorítja mellkasát"→angina pectoris típusú panasz, "dobog a szíve"→palpitatio, "elfullad"→dyspnoea d'effort, "lába dagad"→bilaterális perifériás oedema.
BNO: I20 angina, I21 AMI, I48 pitvarfibrilláció, I50 szívelégtelenség, I10 hypertonia.
Fields: chief_complaint, cardiac_history, risk_factors, current_medications, bp_pulse, heart_sounds, ecg_findings, echo_results, diagnosis_bno, treatment_plan, follow_up.`,
  dermatology:`You are assisting a Hungarian Dermatologist. BNO-10 required.
Convert: "piros folt"→erythemás macula, "kidudorodás"→papula/nodulus, "hólyag"→vesicula/bulla, "viszketés"→pruritus, "hámlás"→desquamatio.
BNO: L20 atópiás dermatitis, L40 psoriasis, L50 urticaria, C44 bőrkarcinoma, L70 acne.
Fields: chief_complaint, lesion_description, skin_type, history, dermoscopy_findings, diagnosis_bno, treatment_plan, follow_up.`,
  neurology:`You are assisting a Hungarian Neurologist. BNO-10 required.
Convert: "fáj a feje"→cephalalgia, "szédül"→vertigo, "zsibbad"→paraesthesia, "reszket"→tremor, "görcsöl"→convulsio.
BNO: G43 migrén, G40 epilepszia, G35 sclerosis multiplex, G20 Parkinson.
Fields: chief_complaint, neurological_symptoms, onset, neuro_exam, imaging_findings, diagnosis_bno, medication_plan, follow_up.`,
  ortho:`You are assisting a Hungarian Orthopaedic Surgeon. BNO-10 required.
Convert: "fáj a térde"→arthralgia genus, "dagadt az ízülete"→articulatio effusio, "ropog"→crepitatio, "merev reggel"→reggeli ízületi merevség.
BNO: M17 gonarthrosis, M16 coxarthrosis, M75 váll szindróma, M54 hátfájás.
Fields: chief_complaint, injury_mechanism, pain_description, functional_limits, exam_findings, imaging_findings, diagnosis_bno, treatment_plan, physio_referral, follow_up.`,
  psychiatry:`You are assisting a Hungarian Psychiatrist. BNO-10 required.
Convert: "szomorú"→depressív hangulat, "szorongó"→anxietas, "nem tud aludni"→insomnia, "hallja a hangokat"→akusztikus hallucináció.
BNO: F32 depressziós epizód, F41 szorongásos zavar, F20 schizophrenia, F31 bipoláris zavar.
Fields: presenting_complaint, psychiatric_history, current_symptoms, mse, current_medications, diagnosis_bno, treatment_plan, risk_assessment, follow_up.`
};

// ── NAV ───────────────────────────────────────────────────────────────────────
function goTo(n){
  document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});
  document.getElementById('p'+n).classList.add('active');
  document.querySelectorAll('.step').forEach(function(s,i){
    s.classList.remove('active','done');
    if(i+1<n)s.classList.add('done');
    if(i+1===n)s.classList.add('active');
  });
}
function pickSpec(k,el){
  document.querySelectorAll('.spec-card').forEach(function(c){c.classList.remove('sel');});
  el.classList.add('sel'); S.specialty=k;
  document.getElementById('btn1').disabled=false;
}
function pickCat(el,cat){
  document.querySelectorAll('.cat-tag').forEach(function(t){t.classList.remove('active');});
  el.classList.add('active'); S.currentCat=cat;
}

// ── RECORDING ─────────────────────────────────────────────────────────────────
function toggleRec(){if(!S.isRec)startRec();else stopRec();}

function startRec(){
  // Create clip entry immediately
  var clipId=Date.now();
  var clip={id:clipId,category:S.currentCat,transcript:'',secs:0,timestamp:new Date().toLocaleTimeString('hu-HU',{hour:'2-digit',minute:'2-digit'})};
  S.clips.push(clip);
  S.activeClipId=clipId;
  renderClips();

  // Speech recognition — try English for better medical term recognition
  // then fall back showing Hungarian words as-is
  if('SpeechRecognition' in window||'webkitSpeechRecognition' in window){
    var SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    S.recog=new SR();
    S.recog.continuous=true;
    S.recog.interimResults=true;
    // Use Hungarian — better for mixed HU+Latin than pure EN
    // Medical terms will need manual correction which is now easy
    S.recog.lang='hu-HU';

    S.recog.onresult=function(e){
      var fin='',interim='';
      for(var i=e.resultIndex;i<e.results.length;i++){
        if(e.results[i].isFinal)fin+=e.results[i][0].transcript+' ';
        else interim+=e.results[i][0].transcript;
      }
      // Update clip transcript in state
      var c=getClip(S.activeClipId);
      if(c){c.transcript=fin.trim();}
      // Update DOM live — find the editable div
      var txEl=document.querySelector('[data-clip-id="'+S.activeClipId+'"] .clip-transcript');
      if(txEl){
        txEl.textContent=(fin+interim).trim()||'Listening...';
      }
    };
    S.recog.onerror=function(e){
      var c=getClip(S.activeClipId);
      if(c&&!c.transcript)c.transcript='[Speech recognition error — please type below]';
      renderClips();
    };
    try{S.recog.start();}catch(ex){}
  }

  // MediaRecorder backup
  navigator.mediaDevices.getUserMedia({audio:true}).then(function(stream){
    S.mediaRec=new MediaRecorder(stream);
    S.mediaRec.onstop=function(){stream.getTracks().forEach(function(t){t.stop();});};
    S.mediaRec.start();
  }).catch(function(){});

  S.isRec=true; S.secs=0;
  document.getElementById('rec-btn').classList.add('rec');
  document.getElementById('mic-ic').style.display='none';
  document.getElementById('stop-ic').style.display='block';
  document.getElementById('wf').classList.add('on');
  document.getElementById('rec-timer').classList.add('show');
  document.getElementById('rec-status').textContent='Recording clip #'+S.clips.length+'...';

  S.timerInt=setInterval(function(){
    S.secs++;
    var m=Math.floor(S.secs/60),sec=String(S.secs%60).padStart(2,'0');
    document.getElementById('rec-timer').textContent=m+':'+sec;
    var c=getClip(S.activeClipId); if(c)c.secs=S.secs;
  },1000);
}

function stopRec(){
  if(S.recog){try{S.recog.stop();}catch(e){}}
  if(S.mediaRec&&S.mediaRec.state!=='inactive')S.mediaRec.stop();
  clearInterval(S.timerInt); S.isRec=false;

  // Sync final text from DOM to state (in case user edited live)
  var txEl=document.querySelector('[data-clip-id="'+S.activeClipId+'"] .clip-transcript');
  var c=getClip(S.activeClipId);
  if(c&&txEl){
    c.transcript=txEl.textContent.trim()||'['+c.secs+'s clip — no transcript]';
    c.secs=S.secs;
  }

  document.getElementById('rec-btn').classList.remove('rec');
  document.getElementById('mic-ic').style.display='block';
  document.getElementById('stop-ic').style.display='none';
  document.getElementById('wf').classList.remove('on');
  document.getElementById('rec-status').textContent='Clip saved. You can edit the text or record another.';

  S.activeClipId=null;
  renderClips();
  checkDictReady();
}

function getClip(id){return S.clips.find(function(c){return c.id===id;});}

function updateClipCat(id,newCat){
  var c=getClip(id); if(c)c.category=newCat;
  // Update badge color
  var badge=document.querySelector('[data-clip-id="'+id+'"] .clip-cat-select');
  if(badge){
    var col=CAT_COLORS[newCat]||'#8a8a92';
    badge.style.color=col;
    badge.style.borderColor=col+'60';
    badge.style.background=col+'15';
  }
}

function syncTranscript(id,el){
  var c=getClip(id); if(c)c.transcript=el.textContent.trim();
  checkDictReady();
}







function removeClip(id){
  S.clips=S.clips.filter(function(c){return c.id!==id;});
  if(!S.isRec){
    document.getElementById('rec-timer').textContent='0:00';
    document.getElementById('rec-timer').classList.remove('show');
    document.getElementById('rec-status').textContent='Press to record a dictation clip';
    S.secs=0;
  }
  renderClips(); checkDictReady();
}

function renderClips(){
  var list=document.getElementById('clips-list');
  var empty=document.getElementById('clips-empty');
  var footer=document.getElementById('clips-footer');
  document.getElementById('clips-count').textContent=S.clips.length+(S.clips.length===1?' clip':' clips');

  if(!S.clips.length){
    empty.style.display='flex'; list.style.display='none'; footer.style.display='none'; return;
  }
  empty.style.display='none'; list.style.display='flex'; footer.style.display='block';

  list.innerHTML='';
  S.clips.forEach(function(clip,i){
    var col=CAT_COLORS[clip.category]||'#8a8a92';
    var isLive=clip.id===S.activeClipId;
    var div=document.createElement('div');
    div.className='clip-item'+(isLive?' recording-now':'');
    div.setAttribute('data-clip-id',clip.id);

    // Build cat select options
    var opts=CATS.map(function(cat){
      return '<option value="'+cat+'"'+(cat===clip.category?' selected':'')+'>'+cat+'</option>';
    }).join('');

    div.innerHTML=
      '<div class="clip-item-hdr">'+
        '<div class="clip-num">'+(i+1)+'</div>'+
        '<select class="clip-cat-select" style="color:'+col+';border-color:'+col+'60;background:'+col+'15" onchange="updateClipCat('+clip.id+',this.value)">'+opts+'</select>'+
        '<span class="clip-time">'+clip.timestamp+(clip.secs?' · '+clip.secs+'s':'')+'</span>'+
        '<span class="clip-rm" onclick="removeClip('+clip.id+')">×</span>'+
      '</div>'+
      '<div class="clip-transcript-wrap">'+
        '<div class="clip-transcript'+(isLive?' live':'')+'" contenteditable="true" oninput="syncTranscript('+clip.id+',this)" onblur="syncTranscript('+clip.id+',this)">'+
          (clip.transcript||(isLive?'Listening...':'[empty — click to edit]'))+
        '</div>'+
        '<div class="clip-edit-hint">✏ Click to edit transcript</div>'+
      '</div>';
    list.appendChild(div);
  });

  var words=S.clips.reduce(function(a,c){return a+(c.transcript?c.transcript.split(/\s+/).length:0);},0);
  document.getElementById('total-words').textContent=words;
}

function checkDictReady(){
  var ok=S.clips.length>0&&S.clips.some(function(c){return c.transcript&&c.transcript.length>5;});
  document.getElementById('btn2').disabled=!ok;
}

// ── FILES ─────────────────────────────────────────────────────────────────────
function dov(e){e.preventDefault();}
function ddr(e,t){e.preventDefault();var fs=e.dataTransfer.files;for(var i=0;i<fs.length;i++)handleFile(fs[i],t);}
function addF(e,t){var fs=e.target.files;for(var i=0;i<fs.length;i++)handleFile(fs[i],t);e.target.value='';}
function getFT(n){var e=n.split('.').pop().toLowerCase();if(['jpg','jpeg','png','bmp','tiff','tif'].includes(e))return'image';if(e==='pdf')return'pdf';if(['doc','docx'].includes(e))return'docx';return'txt';}
function handleFile(file,type){
  var ft=getFT(file.name);
  var entry={file:file,name:file.name,ftype:ft,extracted:'',status:'loading',isImage:ft==='image'};
  if(type==='t'){S.tFiles=[entry];}else{S.pFiles.push(entry);}
  renderLists(); extractContent(entry);
}
function extractContent(entry){
  var reader=new FileReader();
  if(entry.isImage){
    reader.onload=function(e){entry.extracted=e.target.result;entry.status='ok';renderLists();checkDocReady();};
    reader.readAsDataURL(entry.file);
  } else {
    reader.onload=function(e){
      var clean=e.target.result.replace(/[^\x20-\x7E\n\r\t\u00C0-\u024F]/g,' ').trim();
      entry.extracted=clean.length>30?clean:'[Binary: '+entry.name+']';
      entry.status=clean.length>30?'ok':'warn';
      renderLists();checkDocReady();
    };
    reader.onerror=function(){entry.extracted='[Error: '+entry.name+']';entry.status='warn';renderLists();checkDocReady();};
    reader.readAsText(entry.file);
  }
}
function checkDocReady(){document.getElementById('btn-proc').disabled=!(S.tFiles.length>0&&S.tFiles[0].status!=='loading');}
function renderLists(){
  rList('t-list',S.tFiles,'t'); rList('p-list',S.pFiles,'p');
  if(S.tFiles.length>0)document.getElementById('tz').classList.add('filled');
  if(S.pFiles.length>0)document.getElementById('pz').classList.add('filled');
}
function rList(id,files,type){
  var el=document.getElementById(id); el.innerHTML='';
  files.forEach(function(f,i){
    var cls='ft-'+(f.ftype==='image'?'img':f.ftype==='pdf'?'pdf':f.ftype==='docx'?'doc':'txt');
    var st=f.status==='ok'?'✓ Ready':f.status==='loading'?'⏳ Reading...':'⚠ Binary';
    var sc=f.status==='ok'?'ok':f.status==='loading'?'loading':'warn';
    el.innerHTML+='<div class="file-item"><div class="fi-left"><span class="ft '+cls+'">'+f.ftype.toUpperCase()+'</span><div><div class="fi-name">'+f.name+'</div><div class="fi-status '+sc+'">'+st+'</div></div></div><span class="fi-rm" onclick="rmFile(\''+type+'\','+i+')">×</span></div>';
  });
}
function rmFile(t,i){if(t==='t'){S.tFiles.splice(i,1);document.getElementById('tz').classList.remove('filled');}else{S.pFiles.splice(i,1);}renderLists();checkDocReady();}

// ── PROCESS ───────────────────────────────────────────────────────────────────
async function runProcess(){
  if(!S.tFiles.length||!S.clips.length)return;
  goTo(4);
  document.getElementById('proc-card').classList.add('on');
  document.getElementById('rev').style.display='none';

  var stages=['ps0','ps1','ps2','ps3','ps4'];
  var labels=['Merging clips...','Converting terminology...','Structuring context...','Filling template...','Attributing sources...'];
  var si=0;
  var si_int=setInterval(function(){
    if(si>0)document.getElementById(stages[si-1]).classList.replace('active','done');
    if(si<stages.length){document.getElementById(stages[si]).classList.add('active');document.getElementById('proc-sub').textContent=labels[si];si++;}
  },900);

  var mergedTx=S.clips.map(function(c,i){return '[Clip '+(i+1)+' — '+c.category+']: '+c.transcript;}).join('\n\n');
  var specP=SPEC[S.specialty]||SPEC.gp;
  var tmpl=S.tFiles[0].extracted;
  var sdocs=S.pFiles.map(function(f,i){return{id:'doc_'+i,name:f.name,ftype:f.ftype,content:f.extracted,isImage:f.isImage};});
  var srcIds='dictation = physician dictation';
  sdocs.forEach(function(d){srcIds+=', '+d.id+' = '+d.name;});

  var sysP=specP+'\n\nThe physician dictation consists of multiple short clips tagged by category.\nRULES:\n1. Fill ONLY empty template fields from explicitly present sources.\n2. Convert colloquial to clinical terminology.\n3. NEVER invent information.\n4. Leave uncertain fields empty.\n5. Record source_id per field. Source IDs: '+srcIds+'\nReturn ONLY JSON: {"fields":[{"label":"...","value":"...","source":"..."},...]}';

  var content=[];
  sdocs.forEach(function(d){
    if(d.isImage&&d.content.startsWith('data:image')){
      var mm=d.content.match(/data:([^;]+);base64,/);
      content.push({type:'image',source:{type:'base64',media_type:mm?mm[1]:'image/jpeg',data:d.content.replace(/^data:[^;]+;base64,/,'')}});
      content.push({type:'text',text:'[Image: '+d.name+' (source_id: '+d.id+')]'});
    }
  });
  var txt='=== PHYSICIAN DICTATION (source_id: dictation) ===\n'+mergedTx+'\n\n';
  sdocs.forEach(function(d){if(!d.isImage)txt+='=== DOCUMENT: '+d.name+' (source_id: '+d.id+') ===\n'+d.content+'\n\n';});
  txt+='=== TEMPLATE TO FILL ===\n'+tmpl+'\nReturn JSON.';
  content.push({type:'text',text:txt});

  try{
    var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:2000,system:sysP,messages:[{role:'user',content:content}]})});
    clearInterval(si_int);
    stages.forEach(function(s){document.getElementById(s).classList.add('done');document.getElementById(s).classList.remove('active');});
    var data=await r.json();
    var parsed;
    try{parsed=JSON.parse(data.content[0].text.replace(/```json|```/g,'').trim());}
    catch(e){parsed={fields:[{label:'Result',value:data.content[0].text,source:'dictation'}]};}
    renderReview(mergedTx,parsed,sdocs);
  }catch(e){
    clearInterval(si_int);
    renderReview(mergedTx,{fields:[{label:'Note',value:'API connection required.',source:''}]},sdocs);
  }
}

function renderReview(tx,parsed,sdocs){
  document.getElementById('proc-card').classList.remove('on');
  document.getElementById('rev').style.display='block';

  var srcMap={dictation:{label:'Physician dictation ('+S.clips.length+' clips)',color:SRC_COLORS.dictation,preview:tx.substring(0,300)+(tx.length>300?'...':'')}};
  sdocs.forEach(function(d,i){
    var col=d.isImage?SRC_COLORS.img:i===0?SRC_COLORS.lab:SRC_COLORS.prev;
    srcMap['doc_'+i]={label:d.name,color:col,preview:d.content.substring(0,260)+(d.content.length>260?'...':'')};
  });

  var leg=document.getElementById('src-legend');
  leg.innerHTML='<span style="font-size:11px;color:var(--gray);margin-right:4px">Sources:</span>';
  Object.keys(srcMap).forEach(function(k){var s=srcMap[k];leg.innerHTML+='<span class="src-chip" style="color:'+s.color+';border-color:'+s.color+'40;background:'+s.color+'15">● '+s.label+'</span>';});
  leg.innerHTML+='<span class="src-chip" style="color:#555;border-color:#55555540;background:#55555515">○ Not mentioned</span>';

  var sl=document.getElementById('src-list'); sl.innerHTML='';
  Object.keys(srcMap).forEach(function(k){var s=srcMap[k];sl.innerHTML+='<div class="src-card"><div class="src-card-hdr"><div class="src-dot" style="background:'+s.color+'"></div><div class="src-name">'+s.label+'</div><div class="src-type">'+(k==='dictation'?'Clips':'Document')+'</div></div><div class="src-body">'+s.preview+'</div></div>';});

  var dc=document.getElementById('filled-doc'); dc.innerHTML='';
  (parsed.fields||[]).forEach(function(f){
    var hasV=f.value&&f.value.trim();
    var src=hasV?(f.source||''):'';
    var col=src&&srcMap[src]?srcMap[src].color:SRC_COLORS.empty;
    var lbl2=src&&srcMap[src]?srcMap[src].label:(hasV?'Unknown':'Not mentioned');
    var div=document.createElement('div'); div.className='doc-field';
    var hdr=document.createElement('div'); hdr.className='doc-field-hdr';
    var lb=document.createElement('div'); lb.className='doc-field-label'; lb.textContent=f.label;
    var sb=document.createElement('span'); sb.className='doc-field-src';
    sb.style.cssText='color:'+col+';border-color:'+col+'40;background:'+col+'12';
    sb.textContent=lbl2;
    hdr.appendChild(lb); hdr.appendChild(sb);
    var vl=document.createElement('div'); vl.className='doc-field-value'+(hasV?'':' empty');
    vl.contentEditable='true'; vl.textContent=hasV?f.value:'[not mentioned]';
    div.appendChild(hdr); div.appendChild(vl); dc.appendChild(div);
  });
  S._srcMap=srcMap;
}

// ── VOICE EDIT ────────────────────────────────────────────────────────────────
function toggleVeRec(){if(!S.isVeRec)startVeRec();else stopVeRec();}
function startVeRec(){
  var txt='';
  if('SpeechRecognition' in window||'webkitSpeechRecognition' in window){
    var SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    S.veRecog=new SR(); S.veRecog.continuous=true; S.veRecog.interimResults=true; S.veRecog.lang='hu-HU';
    S.veRecog.onresult=function(e){var i2='';for(var i=e.resultIndex;i<e.results.length;i++){if(e.results[i].isFinal)txt+=e.results[i][0].transcript+' ';else i2+=e.results[i][0].transcript;}document.getElementById('ve-tx').value=txt+i2;};
    try{S.veRecog.start();}catch(e){}
  }
  S.isVeRec=true; S.veSecs=0;
  document.getElementById('ve-btn').classList.add('rec');
  document.getElementById('ve-mic').style.display='none';
  document.getElementById('ve-stop').style.display='block';
  document.getElementById('ve-status').textContent='Recording correction...';
  document.getElementById('ve-timer').classList.add('show');
  S.veTimerInt=setInterval(function(){S.veSecs++;var m=Math.floor(S.veSecs/60),s=String(S.veSecs%60).padStart(2,'0');document.getElementById('ve-timer').textContent=m+':'+s;},1000);
}
function stopVeRec(){
  if(S.veRecog){try{S.veRecog.stop();}catch(e){}}
  clearInterval(S.veTimerInt); S.isVeRec=false;
  document.getElementById('ve-btn').classList.remove('rec');
  document.getElementById('ve-mic').style.display='block';
  document.getElementById('ve-stop').style.display='none';
  document.getElementById('ve-timer').classList.remove('show');
  document.getElementById('ve-status').textContent='Correction recorded. Apply below.';
}

async function applyCorrection(){
  var inst=document.getElementById('ve-tx').value.trim();
  if(!inst)return;
  var btn=document.getElementById('ve-apply');
  btn.disabled=true; btn.textContent='Applying...';

  var fields=[];
  document.querySelectorAll('.doc-field').forEach(function(f){
    fields.push({label:f.querySelector('.doc-field-label').textContent,value:f.querySelector('.doc-field-value').textContent});
  });

  var specP=SPEC[S.specialty]||SPEC.gp;
  var sysP=specP+'\nUpdate only the affected fields based on the correction instruction. Return ONLY JSON: {"updates":[{"label":"exact label","new_value":"updated value"},...]}';
  var userMsg='CURRENT DOCUMENT:\n'+JSON.stringify(fields,null,2)+'\n\nCORRECTION:\n'+inst+'\n\nReturn only changed fields.';

  try{
    var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:600,system:sysP,messages:[{role:'user',content:userMsg}]})});
    var data=await r.json();
    var parsed=JSON.parse(data.content[0].text.replace(/```json|```/g,'').trim());
    (parsed.updates||[]).forEach(function(u){
      document.querySelectorAll('.doc-field').forEach(function(f){
        var lb=f.querySelector('.doc-field-label');
        var vl=f.querySelector('.doc-field-value');
        if(lb&&lb.textContent===u.label&&vl){
          vl.textContent=u.new_value; vl.classList.remove('empty');
          vl.style.background='rgba(76,173,124,.25)';
          setTimeout(function(){vl.style.background='';},900);
        }
      });
    });
    document.getElementById('ve-tx').value='';
    document.getElementById('ve-status').textContent='Done. Record another correction if needed.';
  }catch(e){
    document.getElementById('ve-status').textContent='Error. Please try again.';
  }
  btn.disabled=false; btn.textContent='Apply correction →';
}

// ── EXPORT ────────────────────────────────────────────────────────────────────
function getDocTxt(){
  var t='VoxSana — Approved Medical Document\n'+new Date().toLocaleString('en-GB')+'\n'+'─'.repeat(50)+'\n\n';
  document.querySelectorAll('.doc-field').forEach(function(f){
    t+=f.querySelector('.doc-field-label').textContent+' ['+f.querySelector('.doc-field-src').textContent+']:\n'+f.querySelector('.doc-field-value').textContent+'\n\n';
  });
  return t+'─'.repeat(50)+'\nApproved by physician. Generated by VoxSana.';
}
function copyDoc(){navigator.clipboard.writeText(getDocTxt()).then(function(){var b=event.target,o=b.textContent;b.textContent='✓ Copied';setTimeout(function(){b.textContent=o;},2000);});}
function dlDoc(){var b=new Blob([getDocTxt()],{type:'text/plain'});var u=URL.createObjectURL(b);var a=document.createElement('a');a.href=u;a.download='voxsana_'+new Date().toISOString().slice(0,10)+'.txt';a.click();URL.revokeObjectURL(u);}
function approveDoc(){
  S.clips=[]; renderClips();
  document.querySelectorAll('.src-body').forEach(function(e){e.textContent='[Deleted]';});
  event.target.disabled=true; event.target.textContent='✓ Approved';
  document.getElementById('suc').classList.add('on');
}

</script>
